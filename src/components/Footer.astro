---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-50 dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 pt-16 pb-8">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2 mb-6">
          <span class="material-symbols-outlined text-3xl text-blue-600">translate</span>
          <h2 class="text-slate-900 dark:text-slate-100 text-xl font-bold tracking-tight">Language Translation USA</h2>
        </div>
        <p class="text-slate-500 dark:text-slate-400 max-w-sm text-sm leading-relaxed">
          Professional certified translation services in Maryland. Serving immigration, legal, medical, and business translation needs with accuracy and speed.
        </p>
      </div>
      
      <!-- Navigation -->
      <div>
        <h4 class="text-slate-900 dark:text-white font-bold text-sm uppercase tracking-widest mb-6">Resources</h4>
        <ul class="space-y-4">
          <li><a href="/immigration-document-translation/" class="text-slate-500 dark:text-slate-400 text-sm hover:text-blue-600 transition-colors">Overview</a></li>
          <li><a href="/immigration-document-translation/tools/" class="text-slate-500 dark:text-slate-400 text-sm hover:text-blue-600 transition-colors">Translation Tools</a></li>
          <li><a href="/immigration-document-translation/challenges/" class="text-slate-500 dark:text-slate-400 text-sm hover:text-blue-600 transition-colors">Common Challenges</a></li>
        </ul>
      </div>
      
      <!-- Legal -->
      <div>
        <h4 class="text-slate-900 dark:text-white font-bold text-sm uppercase tracking-widest mb-6">Site</h4>
        <ul class="space-y-4">
          <li><a href="/" class="text-slate-500 dark:text-slate-400 text-sm hover:text-blue-600 transition-colors">Home</a></li>
          <li><span class="text-slate-500 dark:text-slate-400 text-sm">languagetranslationusa.com</span></li>
        </ul>
      </div>
    </div>
    
    <div class="pt-8 border-t border-slate-200 dark:border-slate-800 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-slate-500 text-xs">&copy; {currentYear} Language Translation USA. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/" class="text-slate-500 text-xs hover:text-blue-600 transition-colors">Privacy Policy</a>
        <a href="/" class="text-slate-500 text-xs hover:text-blue-600 transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
