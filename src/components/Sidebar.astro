---
interface Props {
  keyPoints?: string[];
  relatedLinks?: { name: string; href: string }[];
  showTools?: boolean;
}

const { keyPoints = [], relatedLinks = [], showTools = false } = Astro.props;

const defaultLinks = [
  { name: 'USCIS Translation Requirements', href: 'https://www.uscis.gov/policy-manual/volume-1-part-e-chapter-2' },
  { name: 'ATA Certification', href: 'https://www.atanet.org/certification/' },
];
---

<aside class="space-y-8">
  <!-- Key Points Box -->
  {keyPoints.length > 0 && (
    <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-6">
      <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-blue-600">lightbulb</span>
        Key Points
      </h3>
      <ul class="space-y-3">
        {keyPoints.map((point) => (
          <li class="text-sm text-slate-600 dark:text-slate-400 flex items-start gap-2">
            <span class="material-symbols-outlined text-blue-500 text-sm mt-0.5">check_circle</span>
            {point}
          </li>
        ))}
      </ul>
    </div>
  )}
  
  <!-- Related Links -->
  <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg p-6">
    <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-4 flex items-center gap-2">
      <span class="material-symbols-outlined text-blue-600">link</span>
      Related Resources
    </h3>
    <ul class="space-y-3">
      {relatedLinks.map((link) => (
        <li>
          <a 
            href={link.href}
            class="text-sm text-slate-600 dark:text-slate-400 hover:text-blue-600 transition-colors flex items-start gap-2"
          >
            <span class="material-symbols-outlined text-slate-400 text-sm">open_in_new</span>
            {link.name}
          </a>
        </li>
      ))}
    </ul>
  </div>
  
  <!-- Quick Tools -->
  {showTools && (
    <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg p-6">
      <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-blue-600">build</span>
        Quick Tools
      </h3>
      <div class="space-y-3">
        <a 
          href="/immigration-document-translation/tools/"
          class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2 px-4 rounded-lg transition-colors"
        >
          Document Cost Estimator
        </a>
        <a 
          href="/immigration-document-translation/tools/"
          class="block w-full text-center bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 text-slate-700 dark:text-slate-300 text-sm font-medium py-2 px-4 rounded-lg transition-colors"
        >
          Turnaround Calculator
        </a>
      </div>
    </div>
  )}
</aside>
