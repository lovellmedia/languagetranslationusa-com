---
interface Props {
  title?: string;
}

const { title = "Language Translation USA" } = Astro.props;

const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'Overview', href: '/immigration-document-translation/' },
  { name: 'History', href: '/immigration-document-translation/history/' },
  { name: 'Technical', href: '/immigration-document-translation/technical-deep-dive/' },
  { name: 'Ontology', href: '/immigration-document-translation/ontology/' },
  { name: 'Trends', href: '/immigration-document-translation/trends/' },
  { name: 'Tools', href: '/immigration-document-translation/tools/' },
  { name: 'Challenges', href: '/immigration-document-translation/challenges/' },
];
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 dark:border-slate-800 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-3xl text-blue-600">translate</span>
        <a href="/" class="text-slate-900 dark:text-slate-100 text-lg font-bold tracking-tight">
          {title}
        </a>
      </div>
      
      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-6">
        {navLinks.slice(0, 5).map((link) => (
          <a 
            href={link.href} 
            class="text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 text-sm font-medium transition-colors"
          >
            {link.name}
          </a>
        ))}
        <div class="relative group">
          <button class="text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 text-sm font-medium transition-colors flex items-center gap-1">
            More
            <span class="material-symbols-outlined text-sm">expand_more</span>
          </button>
          <div class="absolute top-full right-0 mt-2 w-48 bg-white dark:bg-slate-800 rounded-lg shadow-xl border border-slate-200 dark:border-slate-700 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
            {navLinks.slice(5).map((link) => (
              <a 
                href={link.href} 
                class="block px-4 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-slate-50 dark:hover:bg-slate-700 first:rounded-t-lg last:rounded-b-lg"
              >
                {link.name}
              </a>
            ))}
          </div>
        </div>
      </nav>
      
      <!-- Mobile Menu Button -->
      <button 
        id="mobile-menu-btn" 
        class="lg:hidden p-2 text-slate-600 dark:text-slate-400 hover:text-blue-600"
        aria-label="Toggle menu"
      >
        <span class="material-symbols-outlined text-2xl" id="menu-icon">menu</span>
      </button>
    </div>
    
    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden lg:hidden border-t border-slate-200 dark:border-slate-800 py-4">
      <nav class="flex flex-col gap-2">
        {navLinks.map((link) => (
          <a 
            href={link.href} 
            class="px-4 py-2 text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors"
          >
            {link.name}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>

<script is:inline>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  
  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
      if (menuIcon) {
        menuIcon.textContent = mobileMenu.classList.contains('hidden') ? 'menu' : 'close';
      }
    });
  }
</script>
